---
import Layout from '../layouts/Layout.astro';
import SearchIsland from '../components/SearchIsland.svelte';
import platformsData from '../data/platforms.json';

const sortedPlatforms = platformsData;
---

<Layout title="Workbound - The Premium Remote Work Directory">
  <div class="mb-20 mt-8">
    <div class="max-w-5xl mb-12">
      <h2 class="text-5xl md:text-6xl lg:text-[5rem] text-ink font-extrabold tracking-tighter leading-[1.05] mb-8">
        The definitive master directory of global remote work.
      </h2>
      <p class="text-xl md:text-2xl lg:text-3xl text-ink/70 mt-6 leading-relaxed font-medium tracking-tight max-w-4xl">
        Curated to eliminate regional noise, connecting you with borderless opportunities.
        <span class="text-accent font-semibold block mt-3">Prioritizing high-intent Non-Tech and AI-augmented roles.</span>
      </p>
    </div>
  </div>

  <!-- Intentionally load Svelte client-side to take over fuzzy search. -->
  <SearchIsland platforms={sortedPlatforms} client:load />

  <footer class="mt-40 border-t border-ink/10 pt-10 flex flex-col sm:flex-row items-center justify-between text-ink/40 text-xs font-bold tracking-[0.2em] uppercase">
    <p>© {new Date().getFullYear()} WORKBOUND. THE GLOBAL PROFESSIONAL.</p>
    <div class="flex gap-8 mt-6 sm:mt-0">
      <a href="#" class="hover:text-accent transition-colors">PRIVACY</a>
      <a href="#" class="hover:text-accent transition-colors">TERMS</a>
    </div>
  </footer>
</Layout>
